# ============================================================
# Token-Free Gateway — environment variable configuration
# All variables use the TFG_ prefix to avoid conflicts.
#
# Alternatively, you can put these settings in:
#   ~/.token-free-gateway/config.json
#
# Priority: TFG_* env vars > config.json > built-in defaults
# ============================================================

# Gateway API key for client authentication (optional).
# Leave empty to disable auth (any client can connect).
TFG_API_KEY=

# Server listen port (default: 3456)
# TFG_PORT=3456

# Chrome debug port URL used for browser-side requests and webauth (default: http://127.0.0.1:9222)
# TFG_CDP_URL=http://127.0.0.1:9222
